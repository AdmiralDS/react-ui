{
  "name": "@admiral-ds/react-ui",
  "version": "8.65.0",
  "description": "React component library for Admiral design system 2.1",
  "keywords": [
    "AdmiralDS",
    "Admiral",
    "ui",
    "react",
    "library"
  ],
  "author": "Admiral DS team",
  "license": "See license in ./LICENSE",
  "files": [
    "dist",
    "src/components",
    "README.md",
    "tsconfig.json"
  ],
  "types": "dist/index.d.ts",
  "main": "dist/index.cjs.js",
  "module": "dist/index.es.js",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs.js",
      "import": "./dist/index.es.js"
    }
  },
  "sideEffects": false,
  "imports": {
    "#src/*": "./src/*"
  },
  "scripts": {
    "check:full": "npm run format:check && npm run typecheck && npm run build:check && npm run test && npm run storybook:build && npm run test:e2e",
    "format:check": "npm run prettier && npm run lint",
    "format:fix": "npm run prettier:fix && npm run lint:fix",
    "storybook": "storybook dev -p 6006",
    "test": "jest --detectOpenHandles",
    "test:update": "jest -u",
    "test:watch": "jest --watch",
    "test:e2e": "playwright test",
    "test:e2e-ui": "playwright test --ui",
    "lint": "eslint src --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint src --ext .js,.jsx,.ts,.tsx --fix",
    "prettier": "prettier . --check",
    "prettier:fix": "prettier . --write",
    "storybook:build": "storybook build --disable-telemetry --output-dir docs/current",
    "storybook:preview": "npx http-server ./docs/current",
    "docker:playwright": "docker-compose up --abort-on-container-exit playwright",
    "typecheck": "tsc -b tsconfig.json",
    "build": "rm -rf dist && rollup -c --strictDeprecations",
    "build:check": "npm run build && test -f dist/index.d.ts && test -f dist/index.es.js && test -f dist/index.cjs.js && test ! -d dist/src",
    "prepare": "npm run build",
    "release": "standard-version"
  },
  "peerDependencies": {
    "@admiral-ds/fonts": "^2.0.0",
    "react": ">=16.8.1",
    "react-dom": ">=16.8.1",
    "styled-components": ">=5.1.0"
  },
  "devDependencies": {
    "@admiral-ds/flags": "^3.1.3",
    "@admiral-ds/fonts": "^2.0.0",
    "@admiral-ds/icons": "^4.6.0",
    "@babel/preset-env": "^7.29.7",
    "@babel/preset-react": "^7.29.7",
    "@babel/preset-typescript": "^7.29.7",
    "@happy-dom/jest-environment": "^20.10.1",
    "@maskito/core": "^5.2.2",
    "@maskito/kit": "^5.2.2",
    "@maskito/react": "^5.2.2",
    "@playwright/test": "^1.60.0",
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@rollup/plugin-url": "^8.0.2",
    "@storybook/addon-designs": "^7.0.9",
    "@storybook/addon-essentials": "^7.6.24",
    "@storybook/addon-interactions": "^7.6.24",
    "@storybook/addon-links": "^7.6.24",
    "@storybook/addon-styling": "^1.3.7",
    "@storybook/blocks": "^7.6.24",
    "@storybook/react": "^7.6.24",
    "@storybook/react-webpack5": "^7.6.24",
    "@styled/typescript-styled-plugin": "^1.0.1",
    "@svgr/rollup": "^8.1.0",
    "@svgr/webpack": "^8.1.0",
    "@tanstack/react-query": "^5.101.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.5.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.19.41",
    "@types/react": "^18.3.30",
    "@types/react-dom": "^18",
    "@types/serve-static": "^1.15.7",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "babel-plugin-styled-components": "^2.3.0",
    "dayjs": "^1.11.21",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-config-x": "^1.0.1",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.6",
    "file-loader": "^6.2.0",
    "happy-dom": "^20.10.1",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "jest-styled-components": "^7.4.0",
    "prettier": "^3.8.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.16.0",
    "resize-observer-polyfill": "^1.5.1",
    "rollup": "^4.61.1",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "rollup-plugin-tsc-alias": "^1.1.2",
    "standard-version": "^9.5.0",
    "storybook": "^7.6.24",
    "storybook-addon-dir": "^1.0.6",
    "storybook-dark-mode": "4.0.1",
    "styled-components": "^6.4.2",
    "ts-jest": "^29.4.11",
    "tsconfig-paths-webpack-plugin": "^4.1.0",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.60.1",
    "typescript-plugin-styled-components": "^3.0.0"
  },
  "repository": "https://github.com/AdmiralDS/react-ui",
  "bugs": {
    "url": "https://github.com/AdmiralDS/react-ui/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
