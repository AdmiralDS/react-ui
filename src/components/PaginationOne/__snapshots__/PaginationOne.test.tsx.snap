.c11:focus-visible {
  outline-offset: 2px;
  outline: var(--admiral-color-Primary_Primary60Main, #0062FF) solid 2px;
}

.button-group[data-dimension='xl'] .c11.c11,
.c11[data-dimension='xl'] {
  padding: 0;
  height: 56px;
  width: 56px;
  font-family: var(--admiral-font-family, 'VTB Group UI', sans-serif);
  font-style: normal;
  font-weight: var(--admiral-font-weight-Button_Button1, 500);
  font-size: var(--admiral-font-size-Button_Button1, 16px);
  line-height: var(--admiral-line-height-Button_Button1, 24px);
  font-feature-settings: 'tnum' on,'lnum' on;
  text-rendering: geometricPrecision;
}

.button-group[data-dimension='l'] .c11.c11,
.c11[data-dimension='l'] {
  height: 48px;
  width: 48px;
}

.button-group[data-dimension='m'] .c11.c11,
.c11[data-dimension='m'] {
  height: 40px;
  width: 40px;
}

.button-group[data-dimension='s'] .c11.c11,
.c11[data-dimension='s'] {
  height: 32px;
  width: 32px;
  font-family: var(--admiral-font-family, 'VTB Group UI', sans-serif);
  font-style: normal;
  font-weight: var(--admiral-font-weight-Button_Button2, 500);
  font-size: var(--admiral-font-size-Button_Button2, 14px);
  line-height: var(--admiral-line-height-Button_Button2, 20px);
  font-feature-settings: 'tnum' on,'lnum' on;
  text-rendering: geometricPrecision;
}

.c8 {
  display: flex;
}

.c8>button {
  margin-left: 8px;
}

[data-simple='true'] .c8 {
  margin-left: 20px;
}

.c4 {
  transition: transform 0.3s ease-in-out;
  transform: rotate(0deg);
}

.c4 *[fill^='#'] {
  fill: var(--admiral-color-Neutral_Neutral50, #74767B);
}

.c4:hover *[fill^='#'] {
  fill: var(--admiral-color-Primary_Primary70, #0046E2);
}

.c4[data-loading] {
  pointer-events: none;
}

.c4[data-disabled] {
  pointer-events: none;
}

.c4[data-disabled] *[fill^='#'] {
  fill: var(--admiral-color-Neutral_Neutral30, #B2B5B8);
}

.c2 {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 40px;
  padding: 10px 12px;
  border: 2px solid transparent;
  border-radius: var(--admiral-border-radius-Medium, 4px);
  appearance: none;
  -webkit-tap-highlight-color: transparent;
  background-color: transparent;
  font-family: var(--admiral-font-family, 'VTB Group UI', sans-serif);
  font-style: normal;
  font-weight: var(--admiral-font-weight-Body_Body2Long, 400);
  font-size: var(--admiral-font-size-Body_Body2Long, 14px);
  line-height: var(--admiral-line-height-Body_Body2Long, 20px);
  font-feature-settings: 'tnum' on,'lnum' on;
  text-rendering: geometricPrecision;
  color: var(--admiral-color-Neutral_Neutral90, #252629);
}

.c2 *[fill^='#'] {
  fill: var(--admiral-color-Neutral_Neutral50, #74767B);
}

.c2>span {
  min-width: 20px;
}

.c2:hover {
  cursor: pointer;
}

.c2:hover *[fill^='#'] {
  fill: var(--admiral-color-Primary_Primary70, #0046E2);
}

.c2:active *[fill^='#'] {
  fill: var(--admiral-color-Neutral_Neutral50, #74767B);
}

.c2:focus-visible {
  outline: none;
  border-color: var(--admiral-color-Primary_Primary60Main, #0062FF);
}

.c2:disabled {
  cursor: not-allowed;
  color: var(--admiral-color-Neutral_Neutral30, #B2B5B8);
}

.c2:disabled *[fill^='#'] {
  fill: var(--admiral-color-Neutral_Neutral30, #B2B5B8);
}

.c3 {
  width: 20px;
  height: 20px;
}

.c0 {
  display: flex;
  align-items: center;
  font-family: var(--admiral-font-family, 'VTB Group UI', sans-serif);
  font-style: normal;
  font-weight: var(--admiral-font-weight-Body_Body2Long, 400);
  font-size: var(--admiral-font-size-Body_Body2Long, 14px);
  line-height: var(--admiral-line-height-Body_Body2Long, 20px);
  font-feature-settings: 'tnum' on,'lnum' on;
  text-rendering: geometricPrecision;
  white-space: nowrap;
  user-select: none;
  min-width: 696px;
  justify-content: space-between;
  color: var(--admiral-color-Neutral_Neutral90, #252629);
}

.c1 {
  display: flex;
  align-items: center;
}

.c5 {
  width: 1px;
  height: 24px;
  background-color: var(--admiral-color-Neutral_Neutral20, #D7D8DA);
}

.c7 {
  margin: 0 4px;
  min-width: 112px;
}

.c6 {
  min-width: 172px;
  margin: 0 12px;
}

[data-simple='true'] .c6 {
  margin: 0;
}

<div>
  <div
    class="c0"
    data-simple="false"
  >
    <div
      class="c1"
    >
      Items per page:
      <button
        aria-expanded="false"
        aria-label="8 of 100 records"
        class="c2 records-per-page-with-dropdown"
        type="button"
      >
        <span>
          8
        </span>
        <div
          class="c3"
        >
          <div
            aria-hidden="true"
            class="c4"
          />
        </div>
      </button>
      <div
        class="c5"
      />
      <div
        class="c6"
      >
        1-8 of 100
      </div>
    </div>
    <div
      class="c1"
    >
      <div
        class="c5"
      />
      <button
        aria-expanded="false"
        aria-label="Page 1 of 13"
        class="c2 current-page-number-with-dropdown"
        type="button"
      >
        <span>
          1
        </span>
        <div
          class="c3"
        >
          <div
            aria-hidden="true"
            class="c4"
          />
        </div>
      </button>
      <span
        class="c7"
      >
        of 13 pages
      </span>
      <div
        class="c8"
      >
        <button
          aria-label="Previous page"
          class="c9"
          data-appearance="tertiary"
          data-dimension="m"
          disabled=""
          type="button"
        >
          <div
            class="c10"
          >
            <div
              class=""
            >
              <div />
            </div>
          </div>
        </button>
        <button
          aria-label="Next page"
          class="c11"
          data-appearance="tertiary"
          data-dimension="m"
          type="button"
        >
          <div
            class="c10"
          >
            <div
              class=""
            >
              <div />
            </div>
          </div>
        </button>
      </div>
    </div>
  </div>
</div>
`;

exports[`PaginationOne render matches snapshot in simple mode 1`] = `
.c5 {
  vertical-align: top;
  display: inline-flex;
  gap: 8px;
  flex-direction: row;
  flex-wrap: nowrap;
  justify-content: flex-start;
  align-items: center;
  max-width: calc(100% - 0px);
  height: 24px;
}

.c5 >* {
  display: inline-block;
  flex: 0 1 auto;
  white-space: nowrap;
}

.c5 >.{
  flex: 0 0 auto;
}

.c5>svg {
  width: 24px;
  height: 24px;
}

.button-group[data-dimension='m'] .c5.c5,
.button-group[data-dimension='l'] .c5.c5,
.button-group[data-dimension='xl'] .c5.c5 {
  height: 24px;
}

.button-group[data-dimension='m'] .c5.c5>svg,
.button-group[data-dimension='l'] .c5.c5>svg,
.button-group[data-dimension='xl'] .c5.c5>svg {
  width: 24px;
  height: 24px;
}

.button-group[data-dimension='s'] .c5.c5,
[data-dimension='s'] .c5 {
  height: 20px;
}

.button-group[data-dimension='s'] .c5.c5>svg,
[data-dimension='s'] .c5>svg {
  width: 20px;
  height: 20px;
}

.c4 {
  position: relative;
  box-sizing: border-box;
  display: inline-block;
  white-space: nowrap;
  border: none;
  border-radius: var(--admiral-border-radius-Medium, 4px);
  appearance: none;
  vertical-align: middle;
  cursor: not-allowed;
  padding: 0;
  height: 56px;
  width: 56px;
  font-family: var(--admiral-font-family, 'VTB Group UI', sans-serif);
  font-style: normal;
  font-weight: var(--admiral-font-weight-Button_Button1, 500);
  font-size: var(--admiral-font-size-Button_Button1, 16px);
