.c6:focus-visible {
  outline-offset: 2px;
  outline: var(--admiral-color-Primary_Primary60Main, #0062FF) solid 2px;
}

.button-group[data-dimension='xl'] .c6.c6,
.c6[data-dimension='xl'] {
  padding: 0;
  height: 56px;
  width: 56px;
  font-family: var(--admiral-font-family, 'VTB Group UI', sans-serif);
  font-style: normal;
  font-weight: var(--admiral-font-weight-Button_Button1, 500);
  font-size: var(--admiral-font-size-Button_Button1, 16px);
  line-height: var(--admiral-line-height-Button_Button1, 24px);
  font-feature-settings: 'tnum' on,'lnum' on;
  text-rendering: geometricPrecision;
}

.button-group[data-dimension='l'] .c6.c6,
.c6[data-dimension='l'] {
  height: 48px;
  width: 48px;
}

.button-group[data-dimension='m'] .c6.c6,
.c6[data-dimension='m'] {
  height: 40px;
  width: 40px;
}

.button-group[data-dimension='s'] .c6.c6,
.c6[data-dimension='s'] {
  height: 32px;
  width: 32px;
  font-family: var(--admiral-font-family, 'VTB Group UI', sans-serif);
  font-style: normal;
  font-weight: var(--admiral-font-weight-Button_Button2, 500);
  font-size: var(--admiral-font-size-Button_Button2, 14px);
  line-height: var(--admiral-line-height-Button_Button2, 20px);
  font-feature-settings: 'tnum' on,'lnum' on;
  text-rendering: geometricPrecision;
}

.c3 {
  display: flex;
}

.c3>button {
  margin-left: 8px;
}

[data-simple='true'] .c3 {
  margin-left: 20px;
}

.c0 {
  display: flex;
  align-items: center;
  font-family: var(--admiral-font-family, 'VTB Group UI', sans-serif);
  font-style: normal;
  font-weight: var(--admiral-font-weight-Body_Body2Long, 400);
  font-size: var(--admiral-font-size-Body_Body2Long, 14px);
  line-height: var(--admiral-line-height-Body_Body2Long, 20px);
  font-feature-settings: 'tnum' on,'lnum' on;
  text-rendering: geometricPrecision;
  white-space: nowrap;
  user-select: none;
  min-width: 696px;
  justify-content: space-between;
  color: var(--admiral-color-Neutral_Neutral90, #252629);
}

.c1 {
  min-width: auto;
}

.c2 {
  min-width: 172px;
  margin: 0 12px;
}

[data-simple='true'] .c2 {
  margin: 0;
}

<div>
  <div
    class="c0 c1"
    data-simple="true"
  >
    <div
      class="c2"
    >
      1-8 of 100
    </div>
    <div
      class="c3"
    >
      <button
        aria-label="Previous page"
        class="c4"
        data-appearance="tertiary"
        data-dimension="m"
        disabled=""
        type="button"
      >
        <div
          class="c5"
        >
          <div
            class=""
          >
            <div />
          </div>
        </div>
      </button>
      <button
        aria-label="Next page"
        class="c6"
        data-appearance="tertiary"
        data-dimension="m"
        type="button"
      >
        <div
          class="c5"
        >
          <div
            class=""
          >
            <div />
          </div>
        </div>
      </button>
    </div>
  </div>
</div>
`;
