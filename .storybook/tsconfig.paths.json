{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    // Для Storybook не используем alias @admiral-ds/flags из основного tsconfig:
    // он указывает на .d.ts-файл, а webpack должен резолвить пакет в runtime JS.
    "paths": {
      "#src/*": ["../src/*"],
      "@admiral-ds/react-ui": ["../src/index"]
    }
  }
}
